parameters:
    level: 6
    paths:
        - src
    bootstrapFiles:
        - vendor/autoload.php
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # MigrateCommand, MigrateFreshCommand, MigrateRollbackCommand, MigrateStatusCommand
        # reference MigrationRunner from luany/database. The CLI is a global tool that
        # loads the project's own autoloader at runtime (vendor/autoload.php of the project).
        # PHPStan cannot see that runtime dependency — this is the correct architectural design.
        - '#Luany\\Database\\Migration\\MigrationRunner#'

        # DbSeedCommand and MigrateFreshCommand reference SeederRunner from luany/database.
        # Same runtime dependency pattern as MigrationRunner above — resolved at runtime
        # via the project's own vendor/autoload.php, not visible to PHPStan statically.
        - '#Luany\\Database\\Seeder\\SeederRunner#'

        # ProcessManager uses pcntl_signal / pcntl_async_signals / pcntl_signal_dispatch
        # guarded by function_exists() — pcntl is a CLI-only extension not available on
        # Windows or in some CI environments. PHPStan cannot resolve these at static
        # analysis time. At runtime (Linux/macOS) they are available; Windows falls back
        # to register_shutdown_function() which is always available.
        - '#Call to an undefined function pcntl_signal\(\)#'
        - '#Call to an undefined function pcntl_async_signals\(\)#'
        - '#Call to an undefined function pcntl_signal_dispatch\(\)#'