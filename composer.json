{
    "name": "luany/cli",
    "description": "Official CLI for the Luany Framework — scaffold controllers, models, migrations and more.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "António Ambrósio Ngola",
            "email": "antoniongola.dev@gmail.com",
            "homepage": "https://github.com/luany-ecosystem",
            "role": "Lead Engineer"
        }
    ],
    "keywords": ["php", "cli", "luany", "framework", "scaffold"],
    "homepage": "https://github.com/luany-ecosystem/luany-cli",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "LuanyCli\\": "src/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload-dev": {
        "psr-4": {
            "LuanyCli\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php bin/luany-welcome"
        ]
    },
    "bin": [
        "bin/luany"
    ],
    "config": {
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}