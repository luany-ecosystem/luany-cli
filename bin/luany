#!/usr/bin/env php
<?php

define('LUANY_CLI', true);

/*
|--------------------------------------------------------------------------
| Load CLI autoload
|--------------------------------------------------------------------------
*/

$cliAutoload = __DIR__ . '/../../../autoload.php';

if (!file_exists($cliAutoload)) {
    $cliAutoload = __DIR__ . '/../vendor/autoload.php';
}

require $cliAutoload;

/*
|--------------------------------------------------------------------------
| Find project root
|--------------------------------------------------------------------------
*/

$base = LuanyCli\Support\ProjectFinder::findRoot();
define('BASE_DIR', $base);

/*
|--------------------------------------------------------------------------
| Load project autoload
|
| Only loaded when inside a valid Luany project (luany/framework or
| luany/core declared in composer.json) AND dependencies are installed
| (vendor/luany/framework exists).
|
| If the project is detected but not yet installed, the developer
| receives a clear, educative message instead of a fatal error.
|--------------------------------------------------------------------------
*/

$projectAutoload  = BASE_DIR . '/vendor/autoload.php';
$isLuanyProject   = LuanyCli\Support\ProjectFinder::isLuanyProject(BASE_DIR);
$isProjectReady   = is_dir(BASE_DIR . '/vendor/luany/framework');

if ($isLuanyProject
    && $isProjectReady
    && file_exists($projectAutoload)
    && realpath($projectAutoload) !== realpath($cliAutoload)
) {
    require_once $projectAutoload;
}
/*
|--------------------------------------------------------------------------
| Run CLI
|--------------------------------------------------------------------------
*/

LuanyCli\Application::run($argv);