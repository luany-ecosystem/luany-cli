#!/usr/bin/env php
<?php

define('LUANY_CLI', true);

// Global Composer installation: vendor/luany/cli/bin/ → vendor/autoload.php
$autoload = __DIR__ . '/../../../autoload.php';

// Fallback for local development
if (!file_exists($autoload)) {
    $autoload = __DIR__ . '/../vendor/autoload.php';
}

if (!file_exists($autoload)) {
    fwrite(STDERR, "\n  \033[31m✗\033[0m  vendor/autoload.php not found. Run: composer install\n\n");
    exit(1);
}

require $autoload;

define('BASE_DIR', LuanyCli\Support\ProjectFinder::findRoot());

LuanyCli\Application::run($argv);
